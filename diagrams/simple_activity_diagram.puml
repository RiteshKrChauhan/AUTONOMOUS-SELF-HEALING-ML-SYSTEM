@startuml simple_activity_diagram

start

:Train Initial Model;

repeat
    :Stream Data & Predict;
    :Calculate Error;
    
    if (Drift Detected?) then (yes)
        if (Cooldown Ready?) then (yes)
            :Train New Model;
            if (Performance Gate Pass?) then (yes)
                :Shadow Evaluation (20 cycles);
                if (Shadow Better?) then (yes)
                    :Promote Model;
                endif
            endif
        endif
    endif
    
repeat while (More Data?)

:Generate Reports;

stop

@enduml
