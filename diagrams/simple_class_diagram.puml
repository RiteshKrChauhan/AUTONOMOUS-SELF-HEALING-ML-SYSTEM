@startuml simple_class_diagram

top to bottom direction

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "Core System" {
    class MainPipeline {
        +run()
    }
}

MainPipeline -down-|> "ML"
MainPipeline -down-|> "Drift Detection"
MainPipeline -down-|> "Decision & Control"
MainPipeline -down-|> "Evaluation"
MainPipeline -down-|> "Monitoring"

package "ML" {
    top to bottom direction
    class ConfidencePredictor {
        +predict_with_confidence(X)
    }
    class ModelTrainer {
        +train(X, y)
    }
    
    ConfidencePredictor -[hidden]-> ModelTrainer
}

package "Drift Detection" {
    top to bottom direction
    class AnomalyDetector {
        +detect(X)
    }
    class DriftDetector {
        +detect_drift(error)
        +detect_data_drift(data)
    }

    AnomalyDetector -[hidden]-> DriftDetector
}

package "Decision & Control" {
    top to bottom direction
    class AdaptiveCooldown {
        +is_ready(cycle)
        +reset(cycle)
    }
    class DecisionEngine {
        +decide(drift_score)
    }

    AdaptiveCooldown -[hidden]-> DecisionEngine
}

package "Evaluation" {
    top to bottom direction
    class ShadowEvaluator {
        +should_promote()
    }
    class PerformanceGate {
        +evaluate(old_mae, new_mae)
    }

    ShadowEvaluator -[hidden]-> PerformanceGate
}

package "Monitoring" {
    top to bottom direction
    class ErrorMonitor {
        +add_error(error)
        +get_rolling_avg()
    }
}

@enduml
