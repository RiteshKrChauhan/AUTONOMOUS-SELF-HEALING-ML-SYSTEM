@startuml simple_usecase_diagram

left to right direction

actor User
actor "Data Stream" as DS

rectangle "Self-Healing ML System" {
    usecase "Train Model" as UC1
    usecase "Make Predictions" as UC2
    usecase "Detect Drift" as UC3
    usecase "Auto Retrain" as UC4
    usecase "Evaluate & Promote" as UC5
    usecase "Monitor & Log" as UC6
}

User --> UC1
User --> UC6
DS --> UC2

UC2 ..> UC3 : <<include>>
UC3 ..> UC4 : <<extend>>
UC4 ..> UC5 : <<include>>
UC5 ..> UC6 : <<include>>

@enduml
