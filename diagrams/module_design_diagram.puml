@startuml module_design_diagram

skinparam packageStyle rectangle
skinparam defaultFontSize 9
skinparam dpi 150
skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<ml>> LightGreen
    BackgroundColor<<monitoring>> LightYellow
    BackgroundColor<<infrastructure>> LightGray
}

title Module Design

package "Main" {
    [main.py] <<core>>
}

package "ML" <<ml>> {
    [train.py]
    [performance_gate.py]
    [shadow_evaluator.py]
}

package "Drift" <<monitoring>> {
    [drift_detector.py]
    [anomaly_detector.py]
}

package "Decision" <<core>> {
    [decision_engine.py]
    [adaptive_cooldown.py]
}

package "Data" <<core>> {
    [loader.py]
    [error_monitor.py]
}

package "Logging" <<infrastructure>> {
    [logger.py]
    [plotter.py]
    database MLflow
}

[main.py] --> [loader.py]
[main.py] --> [train.py]
[main.py] --> [drift_detector.py]
[main.py] --> [decision_engine.py]
[main.py] --> [logger.py]

[train.py] --> [performance_gate.py]
[performance_gate.py] --> [shadow_evaluator.py]

[drift_detector.py] --> [error_monitor.py]
[decision_engine.py] --> [adaptive_cooldown.py]

[logger.py] --> MLflow
[plotter.py] --> MLflow

@enduml
